#include <iostream>
#include <string>
using namespace std;

class Person {
private:
    int age;
    string gender;

public:
    void setAge(int a) {
        age = a;
    }

    int getAge() {
        return age;
    }

    void setGender(string g) {
        gender = g;
    }

    string getGender() {
        return gender;
    }
};

class Patient : public Person {
public:
    string name, disease, doctor;
    int room_no, days;
    int bill;

    void display() {
        cout << "========================================" << endl;
        cout << "         SMART HOSPITAL RECORD          " << endl;
        cout << "========================================" << endl;

        cout << "Patient Name      : " << name << endl;
        cout << "Age               : " << getAge() << endl;
        cout << "Gender            : " << getGender() << endl;
        cout << "Disease           : " << disease << endl;
        cout << "Doctor Assigned   : " << doctor << endl;
        cout << "Room Number       : " << room_no << endl;
        cout << "Days Admitted     : " << days << endl;
        cout << "Bill Amount       : " << bill << endl;

        if (days > 7)
            cout << "Admission Type    : Long Stay" << endl;
        else
            cout << "Admission Type    : Short Stay" << endl;

        if (bill >= 5000)
            cout << "Bill Status       : High Bill Case" << endl;
        else
            cout << "Bill Status       : Regular Bill Case" << endl;

        cout << "Advice            : Patient needs continuous monitoring" << endl;
        cout << "========================================" << endl;
    }
};

int main() {
    Patient p;
    int age;
    string gender;

    cout << "Enter patient name: ";
    cin >> p.name;

    cout << "Enter age: ";
    cin >> age;
    p.setAge(age);

    cout << "Enter gender: ";
    cin >> gender;
    p.setGender(gender);

    cout << "Enter disease: ";
    cin >> p.disease;

    cout << "Enter doctor name: ";
    cin >> p.doctor;

    cout << "Enter room number: ";
    cin >> p.room_no;

    cout << "Enter days admitted: ";
    cin >> p.days;

    cout << "Enter bill amount: ";
    cin >> p.bill;

    p.display();

    return 0;
}
